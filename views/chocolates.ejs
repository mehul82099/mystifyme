<%- include('partials/header') %>

  <!-- ==================== CHOCOLATES ==================== -->
  <section id="chocolates" style="padding-top: 120px;">
    <div class="section-header">
      <span class="section-eyebrow">The Collection</span>
      <h2 class="section-heading">Choose Your Base</h2>
      <p class="section-desc">Three bases, endless possibilities. Each handcrafted with the finest ingredients.</p>
    </div>

    <div class="chocolate-showcase">
      <% bases.forEach(base => { %>
      <div class="choco-card" id="choco-<%= base.id %>">
        <div class="choco-card-glow"></div>
        <div class="choco-card-inner">
          <div class="choco-card-img-wrap">
            <img src="<%= base.image %>" alt="<%= base.name %> Chocolate" class="choco-card-img">
          </div>
          <div class="choco-card-content">
            <span class="choco-tag"><%= base.tag %></span>
            <h3><%= base.name %></h3>
            <p class="choco-desc"><%= base.description %></p>
            <div class="choco-meta">
              <span class="choco-price">₹<%= base.price %> <small>/ <%= base.unit %></small></span>
              <button class="choco-order-btn" data-product="<%= base.name %> Chocolate" data-price="<%= base.price %>">Order</button>
            </div>
          </div>
        </div>
      </div>
      <% }); %>
    </div>
  </section>

<%- include('partials/footer') %>
