<%- include('partials/header') %>

  <!-- ==================== ORDER ==================== -->
  <section id="order" style="padding-top: 120px; padding-bottom: 60px;">
    <div class="order-container">
      <div class="order-left">
        <span class="section-eyebrow">Place Your Order</span>
        <h2 class="section-heading">Ready to<br><em>Mystify?</em></h2>
        <p class="order-desc">Order via WhatsApp for a personalized experience. Tell us your base, mix-ins, and we'll craft your dream box.</p>
        <a href="https://wa.me/919876543210?text=Hi%20Mystify%20Me%2C%20I%20would%20like%20to%20order%20chocolates!" class="whatsapp-btn" id="whatsapp-btn" target="_blank" rel="noopener">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          <span>Order on WhatsApp</span>
        </a>
        <div class="order-stats">
          <div class="stat">
            <span class="stat-number">500+</span>
            <span class="stat-label">Happy Customers</span>
          </div>
          <div class="stat">
            <span class="stat-number">30 min</span>
            <span class="stat-label">Reply Time</span>
          </div>
          <div class="stat">
            <span class="stat-number">Mon–Sat</span>
            <span class="stat-label">10AM–8PM IST</span>
          </div>
        </div>
      </div>
      <div class="order-right">
        <form id="contact-form" action="https://api.web3forms.com/submit" method="POST">
          <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE">
          <input type="hidden" name="subject" value="New Order — Mystify Me">
          <div class="form-group">
            <input type="text" name="name" id="form-name" placeholder=" " required>
            <label for="form-name">Your Name</label>
            <div class="form-line"></div>
          </div>
          <div class="form-group">
            <input type="tel" name="phone" id="form-phone" placeholder=" " required>
            <label for="form-phone">WhatsApp Number</label>
            <div class="form-line"></div>
          </div>
          <div class="form-group">
            <textarea name="message" id="form-message" rows="3" placeholder=" " required></textarea>
            <label for="form-message">Your Order (Base + Mix-ins)</label>
            <div class="form-line"></div>
          </div>
          <button type="submit" class="form-submit" id="form-submit">
            <span>Send Order</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
          </button>
        </form>
      </div>
    </div>
  </section>

<%- include('partials/footer') %>
