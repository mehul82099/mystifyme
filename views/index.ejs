<%- include('partials/header') %>

  <!-- ==================== HERO ==================== -->
  <section id="hero">
    <div class="hero-bg-container">
      <img src="/images/hero-bg.png" alt="Mystify Me Chocolates" class="hero-bg-img" id="hero-bg-img">
      <div class="hero-gradient-overlay"></div>
    </div>

    <!-- Floating particles -->
    <div class="particles" id="particles"></div>

    <!-- Animated gradient orbs -->
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <div class="hero-content">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        <span>Handcrafted in Jaipur</span>
      </div>
      <h1 class="hero-title" id="hero-title">
        <span class="hero-line hero-line-1">Build your</span>
        <span class="hero-line hero-line-2">dream</span>
        <span class="hero-line hero-line-3">chocolate</span>
      </h1>
      <p class="hero-subtitle">Dil Se Bani Mithaas, Har Bite Mein Khushiyaan!</p>
      <div class="hero-price-badge">
        <span class="price-amount">₹150</span>
        <span class="price-unit">per 70gm pack</span>
      </div>
      <a href="chocolates.html" class="hero-cta" id="hero-cta">
        <span>Explore Collection</span>
        <div class="cta-arrow">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
        </div>
      </a>
    </div>

    <!-- Marquee ticker -->
    <div class="hero-ticker">
      <div class="ticker-track">
        <span>JAIPUR MADE</span><span>✦</span>
        <span>HANDCRAFTED</span><span>✦</span>
        <span>₹150 · 70GM</span><span>✦</span>
        <span>GIFT WRAP</span><span>✦</span>
        <span>NO PRESERVATIVES</span><span>✦</span>
        <span>JAIPUR MADE</span><span>✦</span>
        <span>HANDCRAFTED</span><span>✦</span>
        <span>₹150 · 70GM</span><span>✦</span>
        <span>GIFT WRAP</span><span>✦</span>
        <span>NO PRESERVATIVES</span><span>✦</span>
      </div>
    </div>
  </section>

  <!-- ==================== FEATURES ==================== -->
  <section id="features" style="padding-top: 6rem; padding-bottom: 6rem;">
    <div class="features-grid" style="max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem;">
      <div class="feature-item" style="text-align: center;">
        <div class="feature-icon-wrap" style="font-size: 2.5rem; margin-bottom: 1rem;"><span>🙌</span></div>
        <h4 style="font-family: var(--font-display); font-size: 1.5rem; margin-bottom: 0.5rem;">100% Handcrafted</h4>
        <p style="color: var(--text-muted); font-size: 0.9rem;">Every truffle hand-poured in our Jaipur kitchen</p>
      </div>
      <div class="feature-item" style="text-align: center;">
        <div class="feature-icon-wrap" style="font-size: 2.5rem; margin-bottom: 1rem;"><span>🌿</span></div>
        <h4 style="font-family: var(--font-display); font-size: 1.5rem; margin-bottom: 0.5rem;">No Preservatives</h4>
        <p style="color: var(--text-muted); font-size: 0.9rem;">Pure ingredients, zero artificial additives</p>
      </div>
      <div class="feature-item" style="text-align: center;">
        <div class="feature-icon-wrap" style="font-size: 2.5rem; margin-bottom: 1rem;"><span>🎁</span></div>
        <h4 style="font-family: var(--font-display); font-size: 1.5rem; margin-bottom: 0.5rem;">Gift Wrapped</h4>
        <p style="color: var(--text-muted); font-size: 0.9rem;">Beautiful packaging, ready to gift</p>
      </div>
      <div class="feature-item" style="text-align: center;">
        <div class="feature-icon-wrap" style="font-size: 2.5rem; margin-bottom: 1rem;"><span>🚀</span></div>
        <h4 style="font-family: var(--font-display); font-size: 1.5rem; margin-bottom: 0.5rem;">Quick Delivery</h4>
        <p style="color: var(--text-muted); font-size: 0.9rem;">Shipped fresh within 24 hours</p>
      </div>
    </div>
  </section>

<%- include('partials/footer') %>
