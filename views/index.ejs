<%- include('partials/header') %>

  <!-- ==================== HERO ==================== -->
  <section id="hero" style="display: flex; align-items: center; justify-content: space-between; overflow: hidden; padding-top: 80px;">
    
    <!-- Hero Text (Left) -->
    <div class="hero-content" style="position: relative; z-index: 10; width: 50%; max-width: 600px; padding-left: 5%;">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        <span>Handcrafted in Jaipur</span>
      </div>
      <h1 class="hero-title" id="hero-title" style="margin-left: 0; text-align: left;">
        <span class="hero-line hero-line-1" style="display:block;">Build your</span>
        <span class="hero-line hero-line-2" style="display:block;">dream</span>
        <span class="hero-line hero-line-3" style="display:block;">chocolate</span>
      </h1>
      <p class="hero-subtitle" style="text-align: left;">Dil Se Bani Mithaas, Har Bite Mein Khushiyaan!</p>
      <div class="hero-price-badge" style="justify-content: flex-start;">
        <span class="price-amount">₹150</span>
        <span class="price-unit">per 70gm pack</span>
      </div>
      <a href="/chocolates" class="hero-cta" id="hero-cta" style="margin: 2rem 0;">
        <span>Craft Your Chocolate</span>
        <div class="cta-arrow">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
        </div>
      </a>
    </div>

    <!-- Hero Image (Right) -->
    <div class="hero-image-wrap" style="width: 50%; height: 100%; position: relative; z-index: 5; display: flex; align-items: center; justify-content: center;">
      <div class="vibe-tilt" data-tilt data-tilt-max="4" data-tilt-speed="800" data-tilt-perspective="1000" style="position: relative; width: 100%; display: flex; justify-content: center;">
        <div class="glow-effect" style="position: absolute; inset: -4rem; background: radial-gradient(circle, rgba(212,175,55,0.15) 0%, transparent 65%); z-index: -1; border-radius: 50%; animation: pulse-glow 4s infinite alternate ease-in-out;"></div>
        <img src="/images/hero-3d-tray.png?v=3" alt="Mystify Me Authentic 3D Tray" style="width: 100%; max-width: 600px; border-radius: 20px; object-fit: cover; -webkit-mask-image: radial-gradient(circle at center, black 45%, transparent 85%); mask-image: radial-gradient(circle at center, black 45%, transparent 85%); filter: brightness(1.1) contrast(1.05);">
      </div>
    </div>
  <!-- Closing section is below -->

    <!-- Marquee ticker -->
    <div class="hero-ticker">
      <div class="ticker-track">
        <span>JAIPUR MADE</span><span>✦</span>
        <span>HANDCRAFTED</span><span>✦</span>
        <span>₹150 · 70GM</span><span>✦</span>
        <span>GIFT WRAP</span><span>✦</span>
        <span>NO PRESERVATIVES</span><span>✦</span>
        <span>JAIPUR MADE</span><span>✦</span>
        <span>HANDCRAFTED</span><span>✦</span>
        <span>₹150 · 70GM</span><span>✦</span>
        <span>GIFT WRAP</span><span>✦</span>
        <span>NO PRESERVATIVES</span><span>✦</span>
      </div>
    </div>
  </section>

  <!-- ==================== FEATURES ==================== -->
  <section id="features" style="padding-top: 6rem; padding-bottom: 6rem;">
    <div class="features-grid" style="max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem;">
      <div class="feature-item" style="text-align: center;">
        <div class="feature-icon-wrap" style="font-size: 2.5rem; margin-bottom: 1rem;"><span>🙌</span></div>
        <h4 style="font-family: var(--font-display); font-size: 1.5rem; margin-bottom: 0.5rem;">100% Handcrafted</h4>
        <p style="color: var(--text-muted); font-size: 0.9rem;">Every truffle hand-poured in our Jaipur kitchen</p>
      </div>
      <div class="feature-item" style="text-align: center;">
        <div class="feature-icon-wrap" style="font-size: 2.5rem; margin-bottom: 1rem;"><span>🌿</span></div>
        <h4 style="font-family: var(--font-display); font-size: 1.5rem; margin-bottom: 0.5rem;">No Preservatives</h4>
        <p style="color: var(--text-muted); font-size: 0.9rem;">Pure ingredients, zero artificial additives</p>
      </div>
      <div class="feature-item" style="text-align: center;">
        <div class="feature-icon-wrap" style="font-size: 2.5rem; margin-bottom: 1rem;"><span>🎁</span></div>
        <h4 style="font-family: var(--font-display); font-size: 1.5rem; margin-bottom: 0.5rem;">Gift Wrapped</h4>
        <p style="color: var(--text-muted); font-size: 0.9rem;">Beautiful packaging, ready to gift</p>
      </div>
      <div class="feature-item" style="text-align: center;">
        <div class="feature-icon-wrap" style="font-size: 2.5rem; margin-bottom: 1rem;"><span>🚀</span></div>
        <h4 style="font-family: var(--font-display); font-size: 1.5rem; margin-bottom: 0.5rem;">Quick Delivery</h4>
        <p style="color: var(--text-muted); font-size: 0.9rem;">Shipped fresh within 24 hours</p>
      </div>
    </div>
  </section>

<%- include('partials/footer') %>
